name=host.json
{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond" : 5
      }
    },
    "logLevel": {
      "default": "Information",
      "Function": "Information",
      "Host.Results": "Information",
      "Host.Aggregator": "Information"
    }
  },
  "extensions": {
    "eventHubs": {
      "maxBatchSize": 64,
      "prefetchCount": 256
    },
    "serviceBus": {
      "maxConcurrentCalls": 16
    }
  }
}