# Application
APP_NAME=Fortress
APP_VERSION=1.0.0

# Server
HOST=localhost
PORT=3000
NODE_ENV=development

# API
API_PREFIX=/api/v1

# CORS
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/otic_fortress

# Authentication
JWT_SECRET=replace-with-secure-jwt-secret
JWT_EXPIRES_IN=1h

# Azure
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-with-azure-client-secret
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-otic-fortress-dev

# Azure SQL
AZURE_SQL_SERVER=otic-fortress-sql-server
AZURE_SQL_DATABASE=otic_fortress

# Azure Cosmos DB
COSMOS_DB_ENDPOINT=https://otic-fortress-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=replace-with-cosmos-db-key

# Azure Key Vault
KEY_VAULT_NAME=kv-otic-fortress-dev

# Azure Storage
AZURE_STORAGE_ACCOUNT=oticfortressstorage
AZURE_STORAGE_CONTAINER=audit-evidence

# AI Services
AI_PROVIDER=azure-openai
AI_MODEL=gpt-4o-mini

# Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password

# Monitoring
APPLICATION_INSIGHTS_CONNECTION_STRING=replace-with-application-insights-connection-string

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined